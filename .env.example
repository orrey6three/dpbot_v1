# Скопируй в .env и заполни:
#   cp .env.example .env

# ---------- MTProto (если нет TELEGRAM_BOT_TOKEN + WEBHOOK_PUBLIC_URL)
API_ID=
API_HASH=
STRING_SESSION=
SESSION_ENABLED=true

# Доп. аккаунты (опционально)
# API_ID_2=  API_HASH_2=  STRING_SESSION_2=  SESSION_ENABLED_2=true

# ---------- Чаты и город
CHAT_SHUMIKHA_ID=
CHAT_SHCHUCHYE_ID=
CHAT_MISHKINO_ID=
# или fallback: CHAT_ID=  CITY_NAME=

DEFAULT_CITY=Шумиха
LOG_TIMEZONE=Asia/Yekaterinburg
PORT=3000

# ---------- Бэкенд DPS / бот
BOT_TOKEN=
API_URL=https://example.com/api/patrol
YANDEX_MAPS_API_KEY=

# ---------- Cron: очистка голосов на сайте DPS (node-cron внутри бота)
# Полный URL endpoint на Next/Vercel — тот же проект, где задан CRON_SECRET.
DPS_CRON_VOTES_URL=https://your-domain.example/api/cron/votes-cleanup
# Должен совпадать с CRON_SECRET на сайте (dps_posts .env / Vercel / GitHub Secrets).
DPS_CRON_SECRET=
# Расписание cron (по умолчанию 04:00 в LOG_TIMEZONE). Формат: мин час день месяц день_недели
DPS_VOTES_CRON_SCHEDULE=0 4 * * *

# ---------- OpenRouter (парсинг сообщений, Gemini)
OPENROUTER_API_KEY=
# OPENROUTER_MODEL=google/gemini-2.5-flash
# OPENROUTER_MODEL_FALLBACKS=google/gemini-flash-1.5
# OPENROUTER_MODELS=model1,model2
# OPENROUTER_JSON_MODE=true
# OPENROUTER_HTTP_REFERER=https://your-site.example
# OPENROUTER_APP_TITLE=DPS bot
# LLM_MAX_ROUNDS=5
# LLM_429_FAILOVER_DELAY_MS=15000
# LLM_TRANSIENT_FAILOVER_DELAY_MS=5000
# LLM_RATE_LIMIT_COOLDOWN_MS=30000
# LLM_RATE_LIMIT_COOLDOWN_MAX_MS=180000
# AI_MIN_GAP_MS=1500

# ---------- Webhook-режим (опционально)
# TELEGRAM_BOT_TOKEN=
# TG_TOKEN=
# WEBHOOK_PUBLIC_URL=https://your-host.example
# TELEGRAM_MODE=webhook
